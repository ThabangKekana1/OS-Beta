# =============================================================================
# 1OS environment configuration
#
# For local dev:   copy this file to `.env.local` and fill in values.
# For production:  set these in your hosting provider (Vercel, Render, etc.).
#
# REQUIRED for production are marked [PROD-REQUIRED]. Missing values will
# cause /api/healthz to return 503 and most routes to refuse to operate.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development

# --- Auth ------------------------------------------------------------------
# Auth is handled entirely by Supabase Auth. No app-level secret required.
# Provision admins/sales/partners by inviting them from the Supabase dashboard
# (or via the partner-orgs invite API) and adding a matching row in the
# `oneos_users` table with the right role + agent_id.

# --- Supabase [PROD-REQUIRED] -----------------------------------------------
# Create a project at https://supabase.com, then run the migrations in
# supabase/migrations/ via `supabase db push` or the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Canonical site origin used for Supabase auth redirects in production.
NEXT_PUBLIC_SITE_URL=

# Storage bucket used for uploaded documents (auto-created if missing).
ONEOS_SUPABASE_BUCKET=oneos-documents

# --- AI assistant [one of GOOGLE_API_KEY or OPENAI_API_KEY required in prod]
AI_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local Ollama is only used in development. Ignored when NODE_ENV=production.
LOCAL_LLM_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b

# Set to true to log full LLM prompt/response cycles (dev only).
DEBUG_AGENT_MODE=false

# --- Notifications + Email --------------------------------------------------
# Resend API key for transactional email. If unset, emails are skipped silently
# but in-dashboard notifications still work.
RESEND_API_KEY=
# From-address shown on fallback outbound mail. Must use the verified Resend domain.
EMAIL_FROM="Foundation-1 <support@foundation-1.co.za>"
# Verified Resend outbound domain. Keep replies.* for Reply-To only.
EMAIL_OUTBOUND_DOMAIN=foundation-1.co.za
# Admin inbox sender options are fixed in code to:
# Karman <karman@foundation-1.co.za>, Sales <sales@foundation-1.co.za>, Support <support@foundation-1.co.za>
# Where admin alerts (EOI signed, customer uploads) get emailed.
ADMIN_NOTIFY_EMAIL=
# Used to build click-through links in emails and server-side auth redirect fallbacks.
APP_BASE_URL=https://1os.foundation-1.co.za

# --- Sales inbox (two-way email via Resend Inbound) -------------------------
# Verified Resend inbound subdomain. Keep this off the root mailbox domain so
# normal webmail/MX hosting can continue to receive @foundation-1.co.za mail.
# Outbound emails sent from the sales inbox use Reply-To: sales+lead-<id>@<domain>
# so inbound replies land back on the matching lead automatically.
EMAIL_REPLY_DOMAIN=replies.foundation-1.co.za
# Webhook signing secret from the Resend dashboard. Required in production.
RESEND_INBOUND_SECRET=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
