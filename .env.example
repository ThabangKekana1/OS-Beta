# =============================================================================
# 1OS environment configuration
#
# For local dev:   copy this file to `.env.local` and fill in values.
# For production:  set these in your hosting provider (Vercel, Render, etc.).
#
# REQUIRED for production are marked [PROD-REQUIRED]. Missing values will
# cause /api/healthz to return 503 and most routes to refuse to operate.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development

# --- Auth [PROD-REQUIRED] ---------------------------------------------------
# Random string used to HMAC-sign session cookies. >= 32 chars in production.
# Generate with: `openssl rand -hex 32`
ONEOS_AUTH_SECRET=

# Bootstrap JSON used ONLY on the first deployment to seed the
# `oneos_users` table in Supabase. Once users exist in the DB you may remove
# this variable. Each entry needs a passwordHash in the format:
#   pbkdf2:200000:<saltHex>:<hashHex>
# Use the helper exported from lib/auth-bootstrap.ts (`pbkdf2Hash`).
# Example (one line):
# [{"email":"admin@yourco.com","passwordHash":"pbkdf2:200000:...:...","name":"Admin","role":"admin","agentId":"agent-admin"}]
ONEOS_AUTH_PROFILES_JSON=

# --- Supabase [PROD-REQUIRED] -----------------------------------------------
# Create a project at https://supabase.com, then run the migrations in
# supabase/migrations/ via `supabase db push` or the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket used for uploaded documents (auto-created if missing).
ONEOS_SUPABASE_BUCKET=oneos-documents

# --- AI assistant [one of GOOGLE_API_KEY or OPENAI_API_KEY required in prod]
AI_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local Ollama is only used in development. Ignored when NODE_ENV=production.
LOCAL_LLM_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b

# Set to true to log full LLM prompt/response cycles (dev only).
DEBUG_AGENT_MODE=false
